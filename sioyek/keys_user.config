# sioyek user keybindings - overrides ~/.local/share/sioyek/keys.config
# Keep this file ASCII-only: the wifstream config parser silently stops
# at the first multi-byte UTF-8 char (em-dash, box-drawing, arrows, etc.),
# so any bindings past such a char would be skipped without warning.

# Arrow keys for page navigation (matches zathura: <Right>=next, <Left>=prev).
# Overrides upstream's default where arrow keys do horizontal pan.
next_page     <right>
previous_page <left>

# F8 toggles gruvbox custom-color mode on/off
# (F8 is upstream's commented-out default for this command).
toggle_custom_color <f8>

# NOTE: <f7> is intentionally left at the upstream default (toggle_visual_scroll).
# Smooth scrolling is already enabled at startup via prefs_user.config.
# For hue-preserving dark mode use the command palette: type :toggle_dark_mode + Enter.

# Keyboard-driven smart jump - upstream defaults you already have:
#   F  -> keyboard_smart_jump   (vimium hints for citations / fig refs)
#   f  -> open_link             (vimium hints for native PDF links)
#   v  -> keyboard_select       (start text selection from cursor)
#
# Bind keyboard_overview so you can preview the target in an overview window
# without jumping (Alt+f to complement the f / F family of hint commands).
keyboard_overview <A-f>

_wike sw
_scholar ss

# i   -> jump to END of text selection in Neovim (mouse drag or keyboard v-select).
#        The _to_source command is DEFINED in prefs_user.config -- new_command is
#        parsed by the prefs parser (config.cpp), NOT this keybindings file. This
#        line only binds the already-defined command to a key.
# A-i -> synctex at mouse cursor position, no selection needed (original behaviour).
_to_source i
synctex_under_cursor <A-i>

# A-p -> upsert a selected DOI / title into papis (command _papis is defined in
#        prefs_user.config). Opens it if already in the library, else adds it.
_papis <A-p>
