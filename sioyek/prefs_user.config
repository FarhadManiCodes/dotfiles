# sioyek user preferences - overrides ~/.local/share/sioyek/prefs.config

# Page cache: raise from default 5 to 7 for smoother long scrolls.
num_cached_pages 7

# Gruvbox colors used when toggle_custom_color is invoked (F8).
# These map zathura's recolor-lightcolor / recolor-darkcolor.
custom_background_color 0.157 0.157 0.157
custom_text_color 0.922 0.859 0.698

# Keep raster image colors when in custom-color / dark mode.
preserve_image_colors_in_dark_mode 1

# Enable smooth (visual) scroll on startup.
startup_commands toggle_visual_scroll

# Use full window width when fit-to-width is invoked.
fit_to_page_width_ratio 1.0

# Smartcase search: case-insensitive unless query has uppercase.
smartcase_search 1

# Highlight every search match, not just the current one.
should_highlight_unselected_search 1

# Zoom toward cursor rather than viewport center.
wheel_zoom_on_cursor 1

# SyncTeX inverse search via niri-synctex.
# Sioyek uses %1 (file) %2 (line), NOT zathura's %{input}/%{line}.
inverse_search_command /home/farhad/.local/bin/niri-synctex %1 %2

new_command _wike /usr/sbin/wike -u https://en.wikipedia.org/wiki/Special:Search?search=%{selected_text}
new_command _scholar /home/farhad/.local/bin/scholar-search %{selected_text}
