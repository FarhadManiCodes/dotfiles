# sioyek user preferences - overrides ~/.local/share/sioyek/prefs.config

# Page cache: raise from default 5 to 7 for smoother long scrolls.
num_cached_pages 7

# Gruvbox colors used when toggle_custom_color is invoked (F8).
# These map zathura's recolor-lightcolor / recolor-darkcolor.
custom_background_color 0.157 0.157 0.157
custom_text_color 0.922 0.859 0.698

# Keep raster image colors when in custom-color / dark mode.
preserve_image_colors_in_dark_mode 1

# Enable smooth (visual) scroll on startup.
startup_commands toggle_visual_scroll

# Use full window width when fit-to-width is invoked.
fit_to_page_width_ratio 1.0

# Smartcase search: case-insensitive unless query has uppercase.
smartcase_search 1

# Highlight every search match, not just the current one.
should_highlight_unselected_search 1

# Zoom toward cursor rather than viewport center.
wheel_zoom_on_cursor 1

# SyncTeX inverse search via vimtex (same path as a vimtex-launched sioyek and
# as the 'i' selection jump). Reliably targets the nvim editing the file via
# vimtex's server registry and fires VimtexEventViewReverse to focus foot.
# Sioyek substitutes %1 (file) %2 (line); VimtexInverseSearch wants <line> <file>.
# Full nvim path so it resolves regardless of sioyek's PATH.
inverse_search_command /usr/sbin/nvim --headless -c "VimtexInverseSearch %2 '%1'"

new_command _wike /usr/sbin/wike -u https://en.wikipedia.org/wiki/Special:Search?search=%{selected_text}
new_command _scholar /home/farhad/.local/bin/scholar-search %{selected_text}

# Selection -> Neovim source jump (bound to 'i' in keys_user.config).
# No quotes: sioyek splits the command on whitespace BEFORE expanding %{...} and
# passes each piece as a separate argv. So %{selection_end_document} -> "page x y"
# arrives as ONE argument with spaces; the script re-splits it. Quotes would be
# passed literally and break the file-path arg.
new_command _to_source /home/farhad/.local/bin/sioyek-to-source %{file_path} %{selection_end_document}

# Selection -> papis upsert (bound to <A-p> in keys_user.config). If the selection
# is a DOI: open the matching library entry, else `papis add --from doi`. If it is
# a title/citation: search the library (normalised), else resolve via Crossref and
# pick in fuzzel. %{selected_text} arrives as one space/newline-joined arg.
new_command _papis /home/farhad/.local/bin/sioyek-papis %{selected_text}
