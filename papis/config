# Papis configuration file
# Generated for computational science workflow with LaTeX

[papers]
dir = ~/.local/share/papis/papers

[settings]
# Editor and tools - match system config
editor = nvim
browser = firefox
opentool = sioyek
file-browser = xdg-open

# Default library
default-library = papers

# Document naming - lowercase, hyphens for multi-word titles
doc-paths-lowercase = True
doc-paths-word-separator = -
ref-word-separator = _

# Info file
info-name = info.yaml
local-config-file = .papis.config
notes-name = notes.md

# BibTeX support - for LaTeX integration
bibtex-journal-key = journal
bibtex-unicode = True
bibtex-export-file = False
extra-bibtex-keys = ["doc_url"]
bibtex-ignore-keys = []

# Citation formatting - Harvard style (common in scientific writing)
csl-style = harvard1
csl-formatter = plain

# Reference key generation - base format: smith_2020 (duplicates get _1, _2 suffix manually)
ref-format = {doc[author_list][0][family]}_{doc[year]}
multiple-authors-separator = ' and '
multiple-authors-format = {au[family]}, {au[given]}

# Search and display
match-format = {doc[tags]}{doc.subfolder}{doc[title]}{doc[author]}{doc[year]}{doc[ref]}
header-format = <ansired>{doc.html_escape[title]}</ansired>\n <ansigreen>{doc.html_escape[author]}</ansigreen>\n  <ansiblue>({doc.html_escape[year]})</ansiblue> [<ansiyellow>{doc.html_escape[tags]}</ansiyellow>]
completion-format = {doc[ref]}
completion-help-format = {doc[title]} - {doc[author]}

# Advanced options
add-interactive = False
add-edit = True
use-git = False
mvtool = mv
dir-umask = 493
sort-field = year
sort-reverse = True

# Document organization
add-folder-name = {doc[author_list][0][family]}_{doc[year]}
add-file-name = {doc[title]:.40}

# Deduplication keys + human-readable document description
document-description-format = {doc[title]} - {doc[author]}
unique-document-keys = ['doi', 'isbn', 'isbn10', 'eprint', 'url', 'doc_url']

[tui]
editmode = vi

[ask]
llm = gemini/gemini-3-flash-preview
summary-llm = gemini/gemini-2.5-flash-lite
embedding = openai/Qwen3-Embedding-4B
max-sources = 8
answer-length = about 500 words, but can be longer
# multimodal enrichment of figures/equations/tables (vision model).
# gemini-2.5-flash: strong scientific doc/figure parsing on existing Gemini infra.
# thinking left at default; cap to low/disable only if indexing thousands of figures.
enrichment-llm = gemini/gemini-2.5-flash
