// niri (Wayland) config — KDL format. Reference: https://yalter.github.io/niri/Configuration
// "/-" comments out the following node.

input {
    keyboard {
        xkb {
            layout "us"
            options "ctrl:nocaps"   // caps -> ctrl
        }
    }

    touchpad {
        tap
        dwt
        natural-scroll
        accel-speed 0.2
        middle-emulation
    }

    focus-follows-mouse
    warp-mouse-to-focus
}

// Outputs — list them with `niri msg outputs`.

// Laptop — the anchor at 0,0.
output "eDP-1" {
    mode "1920x1200"
    scale 1.0
    position x=0 y=0
}

// External monitor, portrait (transform "90"; use "270" if it's upside down).
// x=1920 puts it to the right of the laptop; y=-300 aligns the tops.
output "HDMI-A-1" {
    mode "1920x1080"
    scale 1.0
    transform "90"
    position x=1920 y=-300
}

layout {
    gaps 5
    center-focused-column "on-overflow"

    // Widths cycled by switch-preset-column-width (Mod+R).
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    // Catppuccin Mocha: Blue active, Surface2 inactive.
    focus-ring {
        width 2
        active-color "#89b4fa"
        inactive-color "#585b70"
    }

    border {
        width 1
        active-color "#89b4fa"
        inactive-color "#585b70"
        urgent-color "#fab387"   // Peach — windows requesting attention.
    }
}

// ── Startup ──────────────────────────────────────────────────────────────────
spawn-at-startup "foot" "--server"
spawn-at-startup "swaybg" "-i" "/usr/share/backgrounds/fsi-zen.png" "-m" "fill"
spawn-at-startup "sh" "-c" "pkill wob 2>/dev/null; rm -f /tmp/wobpipe; mkfifo /tmp/wobpipe; tail -f /tmp/wobpipe | wob -c $HOME/dotfiles/wob/wob.ini"
spawn-at-startup "/usr/lib/mate-polkit/polkit-mate-authentication-agent-1"
spawn-at-startup "wl-paste" "--watch" "cliphist" "store"
spawn-at-startup "sh" "-c" "sleep 3 && wob-control led-sync"

// Bayreuth: 49.95 N, 11.58 E. Temp: 4200K (night) to 6500K (day).
spawn-at-startup "wlsunset" "-l" "49.9" "-L" "11.6" "-t" "4200" "-T" "6500"

// Warm up study caches at startup (runs in background after 5s delay)
spawn-at-startup "sh" "-c" "sleep 5 && find $HOME/Cloud/gdrive/FAU/Library -mindepth 2 -type f \\( -iname '*.pdf' -o -iname '*.djvu' -o -iname '*.epub' \\) -printf '%P\\n' > $HOME/.cache/book-resources.txt 2>/dev/null"

// Idle management (dim / lock / suspend) now runs as a systemd USER service:
//   dotfiles/systemd/user/swayidle.service   (was: spawn-at-startup "swayidle" ...)
// Moved out of niri so it restarts cleanly. Across s2idle suspend/resume on the
// 7840U, swayidle's idle timers desynced and spuriously fired locks in a loop;
// the service locks DIRECTLY (swaylock -f) instead of via loginctl lock-session
// to kill the self-referential lock loop, and a system-sleep hook
// (dotfiles/system-sleep/restart-swayidle) restarts it on resume.
// Timeouts: 4:50 dim, 5:00 lock, 15:00 suspend (battery only — avoids suspending
// unattended compute jobs on AC, the 7840U STAPM/PPT clamp bug).
// See ~/learning/cpp-linalg/todo_power.md.

// Don't show the hotkey help overlay on startup.
hotkey-overlay {
    skip-at-startup
}

prefer-no-csd
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

animations {
    slowdown 1.0
}

// ── Window rules ─────────────────────────────────────────────────────────────

// Firefox picture-in-picture: floating (app-id matches host + Flatpak Firefox).
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

// Floating scratchpad terminal (Mod+Grave)
window-rule {
    match app-id="scratch-term"
    open-floating true
}

// YouTube Search (yts) — fzf TUI, open floating
window-rule {
    match app-id="yts"
    open-floating true
}

// papis reference-key editor (papis-add-paper) — small floating prompt
window-rule {
    match app-id="papis-ref-edit"
    open-floating true
    default-column-width { fixed 720; }
    default-window-height { fixed 220; }
}

// Tridactyl editor — half height, opens alongside Firefox
window-rule {
    match app-id="tridactyl-editor"
    default-column-width { proportion 0.5; }
    default-window-height { proportion 0.5; }
}

// Block password managers from screen capture (inert until one is installed).
window-rule {
    match app-id=r#"^org\.keepassxc\.KeePassXC$"#
    match app-id=r#"^org\.gnome\.World\.Secrets$"#
    match app-id=r#"^Bitwarden$"#
    match app-id=r#"^1Password$"#

    block-out-from "screen-capture"
}

// Enable rounded corners for all windows (subtle 5px radius)
window-rule {
    geometry-corner-radius 5
    clip-to-geometry true
}

// Study apps default to 50% width for scrollable workflow
window-rule {
    match app-id=r#"firefox"#
    default-column-width { proportion 0.5; }
}

window-rule {
    match app-id="gdocs-sync"
    default-column-width { proportion 0.25; }
}

window-rule {
    match app-id="org.pwmt.zathura"
    default-column-width { proportion 0.5; }
}

window-rule {
    match app-id="foot"
    default-column-width { proportion 0.5; }
}

window-rule {
    match app-id="vimb"
    default-column-width { proportion 0.5; }
    open-maximized false
}

// ── Keybindings ──────────────────────────────────────────────────────────────
// "Mod" = Super on a TTY, Alt when running as a winit window.
binds {
    Mod+Shift+Slash { show-hotkey-overlay; }

    // Launchers
    Mod+T hotkey-overlay-title="Open a Terminal: foot" { spawn "footclient"; }
    // Mod+Return: foot + tmux (attach session "main", create if absent).
    Mod+Return { spawn "foot" "-e" "tmux" "new-session" "-A" "-s" "main"; }
    Mod+D hotkey-overlay-title="Run an Application: fuzzel" { spawn "fuzzel"; }
    Mod+Shift+P hotkey-overlay-title="Search Papers: papis" { spawn "papis-fuzzel"; }
    Mod+B hotkey-overlay-title="Open Firefox" { spawn "firefox"; }
    Mod+P hotkey-overlay-title="Open Firefox (Private)" { spawn "firefox" "--private-window"; }
    Mod+E hotkey-overlay-title="Open File Manager: vifm" { spawn "foot" "--app-id=vifm" "-e" "vifm"; }
    Mod+Shift+A hotkey-overlay-title="Switch Audio Output" { spawn "audio-switch"; }
    Mod+Shift+B hotkey-overlay-title="Bluetooth Manager" { spawn "foot" "-e" "bluetui"; }
    Mod+Shift+W hotkey-overlay-title="WiFi Manager" { spawn "foot" "-e" "impala"; }
    Mod+Shift+M hotkey-overlay-title="Mic Input Control" { spawn "mic-control"; }
    Mod+M hotkey-overlay-title="Media Controls" { spawn "media-menu.sh"; }
    // Lock screen — Ctrl+Alt+L (Mod+L is reserved for Vim navigation).
    Ctrl+Alt+L hotkey-overlay-title="Lock the Screen: swaylock" { spawn "swaylock"; }
    Mod+Shift+S hotkey-overlay-title="Suspend" { spawn "bash" "-c" "echo -e 'Suspend\nCancel' | fuzzel -d --lines 2 --width 20 --prompt 'Suspend? ' | grep -q 'Suspend' && systemctl suspend"; }

    Mod+N { spawn "makoctl" "dismiss" "--all"; }
    Mod+Shift+N hotkey-overlay-title="Status Menu" { spawn "status-menu"; }

    // Mod+` — floating scratchpad terminal (quick lookups, man pages, one-offs).
    Mod+Grave hotkey-overlay-title="Scratchpad Terminal" { spawn "footclient" "--app-id" "scratch-term"; }

    // Ctrl+` — clipboard history (fuzzel, top-right).
    Ctrl+Grave {
        spawn "bash" "-c" "cliphist list | fuzzel -d --anchor top-right --width 40 --lines 20 --x-margin 20 --y-margin 20 | cliphist decode | wl-copy";
    }

    // Mod+z — fuzzel library browser; opens via xdg-open (sioyek/zathura/foliate).
    Mod+z { spawn "book-resources"; }

    Mod+Alt+T hotkey-overlay-title="Toggle Foot Theme" { spawn "toggle-foot-theme.sh"; }
    Mod+F8 hotkey-overlay-title="Toggle Foliate Theme" { spawn "foliate-theme-toggle"; }

    // Audio (wob + wpctl) — work while locked.
    XF86AudioRaiseVolume allow-when-locked=true { spawn "wob-control" "volume-up"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "wob-control" "volume-down"; }
    XF86AudioMute        allow-when-locked=true { spawn "wob-control" "volume-mute"; }
    XF86AudioMicMute     allow-when-locked=true { spawn "wob-control" "mic-mute"; }
    XF86AudioPlay        allow-when-locked=true { spawn "media-menu.sh" "call"; }

    // Brightness (wob + brightnessctl)
    XF86MonBrightnessUp   allow-when-locked=true { spawn "wob-control" "brightness-up"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "wob-control" "brightness-down"; }

    Mod+O repeat=false { toggle-overview; }
    Mod+Q repeat=false { close-window; }

    // Window focus — Vim keys
    Mod+H { focus-column-left; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }
    Mod+L { focus-column-right; }

    // Arrow keys also work for focus
    Mod+Left  { focus-column-left; }
    Mod+Down  { focus-window-down; }
    Mod+Up    { focus-window-up; }
    Mod+Right { focus-column-right; }

    // Move windows — Shift + Vim keys
    Mod+Shift+H { move-column-left; }
    Mod+Shift+J { move-window-down; }
    Mod+Shift+K { move-window-up; }
    Mod+Shift+L { move-column-right; }

    // Move windows — Ctrl + arrows
    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Down  { move-window-down; }
    Mod+Ctrl+Up    { move-window-up; }
    Mod+Ctrl+Right { move-column-right; }

    Mod+Home { focus-column-first; }
    Mod+End  { focus-column-last; }
    Mod+Ctrl+Home { move-column-to-first; }
    Mod+Ctrl+End  { move-column-to-last; }

    // Monitor focus navigation
    Mod+Shift+Left  { focus-monitor-left; }
    Mod+Shift+Down  { focus-monitor-down; }
    Mod+Shift+Up    { focus-monitor-up; }
    Mod+Shift+Right { focus-monitor-right; }

    // Move column to another monitor
    Mod+Shift+Ctrl+Left  { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+Down  { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+Up    { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+Right { move-column-to-monitor-right; }

    // Move column to a named monitor; Mod+Shift+0 also fullscreens on the laptop.
    Mod+Shift+1 { move-column-to-monitor "eDP-1"; }
    Mod+Shift+2 { move-column-to-monitor "HDMI-A-1"; }
    Mod+Shift+0 { spawn "sh" "-c" "niri msg action move-window-to-monitor \"eDP-1\" && niri msg action fullscreen-window"; }

    Mod+Page_Down      { focus-workspace-down; }
    Mod+Page_Up        { focus-workspace-up; }
    Mod+U              { focus-workspace-down; }
    Mod+I              { focus-workspace-up; }
    Mod+Ctrl+Page_Down { move-column-to-workspace-down; }
    Mod+Ctrl+Page_Up   { move-column-to-workspace-up; }
    Mod+Ctrl+U         { move-column-to-workspace-down; }
    Mod+Ctrl+I         { move-column-to-workspace-up; }

    Mod+Shift+Page_Down { move-workspace-down; }
    Mod+Shift+Page_Up   { move-workspace-up; }
    Mod+Shift+U         { move-workspace-down; }
    Mod+Shift+I         { move-workspace-up; }

    // Mouse wheel — workspace/column navigation (rate-limited).
    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }

    Mod+WheelScrollRight      { focus-column-right; }
    Mod+WheelScrollLeft       { focus-column-left; }
    Mod+Ctrl+WheelScrollRight { move-column-right; }
    Mod+Ctrl+WheelScrollLeft  { move-column-left; }

    Mod+Shift+WheelScrollDown      { focus-column-right; }
    Mod+Shift+WheelScrollUp        { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp   { move-column-left; }

    // Workspaces by index (dynamic — out-of-range refers to the bottommost empty one).
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }

    // Consume/expel windows in/out of a column.
    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }
    Mod+Comma  { consume-window-into-column; }
    Mod+Period { expel-window-from-column; }

    Mod+R { switch-preset-column-width; }
    Mod+Shift+R { switch-preset-window-height; }
    Mod+Ctrl+R { reset-window-height; }
    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }
    Mod+Ctrl+F { expand-column-to-available-width; }
    Mod+C { center-column; }

    // NOTE: Ctrl+Minus and Ctrl+Equal are intentionally NOT bound here
    // so they can be used for terminal font size adjustment (Ctrl+Plus/Minus).
    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }

    // Floating / tiling
    Mod+V       { toggle-window-floating; }
    Mod+Shift+V { switch-focus-between-floating-and-tiling; }
    Mod+W { toggle-column-tabbed-display; }

    // Screenshots
    Print       { screenshot; }
    Ctrl+Print  { screenshot-screen; }
    Alt+Print   { screenshot-window; }

    // Escape hatch so a remote-desktop/KVM app can't hold the session hostage.
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }

    Mod+Shift+E hotkey-overlay-title="Power Menu" { spawn "powermenu"; }
    Ctrl+Alt+Delete { quit; }
    Mod+Shift+O { power-off-monitors; }
}
