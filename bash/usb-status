#!/bin/bash
# Waybar custom module: show removable drives (USB block + MTP phones)

MEDIA_DIR="/run/media/$USER"
GVFS_DIR="/run/user/$(id -u)/gvfs"
mounts=()

# Block devices (USB sticks, external drives via udiskie)
while IFS= read -r -d '' entry; do
    mounts+=("$(basename "$entry")")
done < <(find "$MEDIA_DIR" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)

# MTP devices (phones via gvfs-mtp) — dirs start with "mtp:"
while IFS= read -r -d '' entry; do
    name=$(basename "$entry")
    mounts+=("$name")
done < <(find "$GVFS_DIR" -mindepth 1 -maxdepth 1 -name 'mtp:*' -type d -print0 2>/dev/null)

count=${#mounts[@]}

if [[ $count -eq 0 ]]; then
    exit 0
fi

tooltip=$(printf '%s\n' "${mounts[@]}")

if [[ $count -eq 1 ]]; then
    text="󱊡"
else
    text="󱊡 $count"
fi

printf '{"text":"%s","tooltip":"%s","class":"connected"}\n' \
    "$text" \
    "${tooltip//$'\n'/'\n'}"
