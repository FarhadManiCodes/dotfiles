#!/bin/bash
# Mic control via fuzzel dmenu: switch default input or kill active recordings.

default_source=$(pactl get-default-source 2>/dev/null)

entries=""
declare -A kill_ids

# Input sources
while IFS=$'\t' read -r _idx name _rest; do
    marker="  "
    [[ "$name" == "$default_source" ]] && marker="* "
    entries+="[src] ${marker}${name}\n"
done < <(pactl list short sources 2>/dev/null | grep -v monitor)

# Active recordings — use PipeWire object.id (not pactl index) for pw-cli destroy
while IFS=$'\t' read -r oid name; do
    label="[kill] ${name}"
    kill_ids["$label"]="$oid"
    entries+="${label}\n"
done < <(pactl list source-outputs 2>/dev/null | awk '
    /^Source Output #/ { if (oid && name) print oid "\t" name; oid=""; name="" }
    /object\.id =/     { gsub(/"/, "", $NF); oid=$NF }
    /application\.name =/ { match($0, /"([^"]+)"/, a); name=a[1] }
    END                { if (oid && name) print oid "\t" name }
')

[ -z "$entries" ] && { notify-send -a "" "Mic Control" "No inputs or recordings found"; exit 0; }

selected=$(printf '%b' "$entries" | fuzzel --dmenu --prompt " Mic  " --width 50)
[[ -z "$selected" ]] && exit 0

if [[ "$selected" == "[src]"* ]]; then
    name=$(echo "$selected" | sed 's/\[src\] [* ] //')
    pactl set-default-source "$name"
    notify-send -a "" -u low " Default input: $name"
elif [[ "$selected" == "[kill]"* ]]; then
    oid="${kill_ids[$selected]}"
    [[ -n "$oid" ]] && pw-cli destroy "$oid" && notify-send -a "" -u low " Recording stopped"
fi
