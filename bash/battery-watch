#!/bin/bash
# Battery LEVEL alerts via batsignal: low 30%, critical 10%, danger 5%.
# Charge events (plugged/unplugged, charging started/complete) -> power-notify.
#
# No full level (-f) on purpose: with the 80% TLP charge cap the battery sits at
# the limit and batsignal re-announces "full" on every poll (spam). Charge
# completion is an event (BAT0 status transition), handled by power-notify, not a
# polled level. (Also never add -M: in batsignal 1.8.0 it fires a second
# notification on top of the built-in one.)

WARN=$(printf '\U000f007b')
CRIT=$(printf '\U000f0083')
DANG=$(printf '\U000f008e')

exec /usr/bin/batsignal \
    -w 30 -W "${WARN} Battery low" \
    -c 10 -C "${CRIT} Battery critical" \
    -d 5  -D "notify-send -a '' -u critical '${DANG} Battery danger — PLUG IN NOW!'" \
    -m 300
