#!/usr/bin/env bash
# Add a paper to papis from a browser page — called by Tridactyl ,p binding
# Usage: papis-add-paper <importer> <identifier>
# Importers: doi (journal pages), arxiv (arXiv pages — also downloads PDF)
#
# Launched from Firefox (no terminal), so it confirms in a small floating
# footclient window showing the title + DOI/arXiv id. You edit a pre-filled
# reference key (readline) and optionally type tags. Empty key cancels.
# The key is kept UNIQUE — papis allows duplicate refs but papis.nvim's sqlite
# cache enforces UNIQUE(ref), so a clash there would break the nvim side; we
# auto-disambiguate the suggestion and re-prompt on a typed clash.

set -uo pipefail

importer="${1:-}"
identifier="${2:-}"

[[ -z "$importer" || -z "$identifier" ]] && {
    notify-send -u critical "Papis" "Usage: papis-add-paper <importer> <identifier>"
    exit 1
}

# --- fetch metadata (best-effort) for the title + a suggested ref key --------
META_TITLE=""; META_FAMILY=""; META_YEAR=""
fetch_meta() {
    case "$1" in
        doi)
            local j; j=$(curl -sSL -m 8 "https://api.crossref.org/works/$2" 2>/dev/null) || return
            META_TITLE=$(jq -r  '.message.title[0]                  // empty' <<<"$j" 2>/dev/null)
            META_FAMILY=$(jq -r '.message.author[0].family          // empty' <<<"$j" 2>/dev/null)
            META_YEAR=$(jq -r   '.message.issued."date-parts"[0][0] // empty' <<<"$j" 2>/dev/null)
            ;;
        arxiv)
            local x name; x=$(curl -sSL -m 8 "https://export.arxiv.org/api/query?id_list=$2" 2>/dev/null) || return
            # Parse the Atom XML with yq (-p=xml) instead of grep/sed on markup.
            META_TITLE=$(yq -p=xml '.feed.entry.title' <<<"$x" 2>/dev/null \
                          | tr '\n' ' ' | tr -s ' ' | sed 's/^ *//; s/ *$//')
            name=$(yq -p=xml '.feed.entry.author[0].name // .feed.entry.author.name // ""' <<<"$x" 2>/dev/null)
            META_FAMILY=${name##* }
            META_YEAR=$(yq -p=xml '.feed.entry.published // ""' <<<"$x" 2>/dev/null | cut -c1-4)
            ;;
    esac
}

# papis-style citation key: alphanumerics joined by single underscores.
sanitize_ref() { printf '%s' "$1" | sed 's/[^[:alnum:]]\+/_/g; s/^_*//; s/_*$//'; }

# Snapshot existing keys + tags once, read straight from YAML with yq: accurate
# (handles any field content) and faster than papis' Python startup. -o=tsv keeps
# values flat without "---" document separators between files.
papers_glob=("$HOME"/.local/share/papis/papers/*/info.yaml)
existing_refs=$(yq -o=tsv '.ref' "${papers_glob[@]}" 2>/dev/null)
ref_taken() { grep -qxF -- "$1" <<<"$existing_refs"; }
existing_tags=$(yq -o=tsv '.tags[]?' "${papers_glob[@]}" 2>/dev/null | sort -u | paste -sd' ' -)

# Append a/b/c… (then _2, _3…) until the key is free.
free_ref() {
    local base="$1" cand="$1" i
    ref_taken "$cand" || { printf '%s' "$cand"; return; }
    for i in {a..z}; do cand="${base}${i}"; ref_taken "$cand" || { printf '%s' "$cand"; return; }; done
    i=2; while ref_taken "${base}_${i}"; do i=$((i+1)); done; printf '%s' "${base}_${i}"
}

# Prompt for the reference key + tags in a small floating footclient window.
# Sets globals OUT_KEY (sanitised) and OUT_TAGS. Args: <mesg> <key-prefill> <tags-prefill>
OUT_KEY=""; OUT_TAGS=""
prompt_meta() {
    local out; out=$(mktemp)
    # $1..$4 below are positional args for the INNER bash -c, so single quotes
    # are intentional (they must not expand in this outer shell).
    # shellcheck disable=SC2016
    footclient --app-id=papis-ref-edit --title="papis: add reference" \
        bash -c '
            printf "%s\n\nEdit the key, Enter to confirm each field; empty key cancels.\n\n" "$1"
            read -e -r -i "$2" -p "reference key> " k || k=""
            read -e -r -i "$3" -p "tags (space-separated, optional)> " t || t=""
            printf "%s\n%s" "$k" "$t" > "$4"
        ' _ "$1" "$2" "$3" "$out" 2>/dev/null
    OUT_KEY=$(sanitize_ref "$(sed -n 1p "$out" 2>/dev/null)")
    OUT_TAGS=$(sed -n 2p "$out" 2>/dev/null | tr -s ' ' | sed 's/^ *//; s/ *$//')
    rm -f "$out"
}

fetch_meta "$importer" "$identifier"

base=$(sanitize_ref "$META_FAMILY")
[[ -n "$META_YEAR" ]] && base="${base:+${base}_}$META_YEAR"
[[ -z "$base" ]] && base=$(sanitize_ref "$identifier")
suggest=$(free_ref "$base")          # first free variant of the suggestion

mesg="Add to papis:
  ${META_TITLE:-$identifier}
  $importer: $identifier"
[[ -n "$existing_tags" ]] && mesg="$mesg
  existing tags: $existing_tags"

# Prompt, and keep prompting until the chosen key is non-empty and free.
prompt_meta "$mesg" "$suggest" ""
while [[ -n "$OUT_KEY" ]] && ref_taken "$OUT_KEY"; do
    prompt_meta "Key '$OUT_KEY' already exists — choose another.

$mesg" "$OUT_KEY" "$OUT_TAGS"
done
[[ -z "$OUT_KEY" ]] && { notify-send -u low "Papis" "Cancelled"; exit 0; }
ref="$OUT_KEY"; tags="$OUT_TAGS"

notify-send -u low "Papis" "Adding as $ref…\n$identifier"

# --batch is required: --set turns the value into a second metadata source, and
# without it papis prompts to merge importer-vs-command-line (no TTY -> "Aborted!").
if ! output=$(papis add --from "$importer" "$identifier" --no-edit --batch --set ref "$ref" 2>&1); then
    notify-send -u critical "Papis" "Failed to add\n$identifier\n$(tail -1 <<<"$output")"
    exit 1
fi

folder=$(grep -oP "Document folder is '\K[^']+" <<<"$output" | head -1)

# Store tags as a proper YAML list (papis.nvim requires list type, one element per
# tag). papis --set only writes a string, so set the split list with yq directly.
[[ -n "$tags" && -f "$folder/info.yaml" ]] && \
    tags="$tags" yq -i '.tags = (strenv(tags) | split(" "))' "$folder/info.yaml"

tagnote=""; [[ -n "$tags" ]] && tagnote="\\n[$tags]"
nfiles=0; [[ -f "$folder/info.yaml" ]] && nfiles=$(yq '(.files // []) | length' "$folder/info.yaml" 2>/dev/null)
if [[ "${nfiles:-0}" -gt 0 ]]; then
    notify-send -u low "Papis" "Added with PDF ✓\n$ref$tagnote"
else
    notify-send -u normal "Papis" "Added — PDF not downloaded\n$ref$tagnote"
fi
