#!/bin/bash
# Status check menu тАФ fuzzel dmenu, each selection fires a notification.

BAT_FULL=$'яЙА'
BAT_THREE=$'яЙБ'
BAT_HALF=$'яЙВ'
BAT_QUARTER=$'яЙГ'
BAT_EMPTY=$'яЙД'
BOLT=$'тЪб'
CLOCK=$'яАЧ'
THERM=$'яЛЙ'
CHIP=$'яЛЫ'

WORLD=$(printf '\U000f01e7')
NET=$(printf '\U000f059f')    # nf-md-web (globe)
WIFI=$(printf '\U000f05a9')   # nf-md-wifi
ETH=$(printf '\U000f0200')    # nf-md-ethernet
choice=$(printf "${BAT_FULL} Battery\n${NET} Internet\n${CLOCK} Uptime\n${THERM} CPU Temp\n${CHIP} Memory\n${WORLD} Time" \
    | fuzzel --dmenu --prompt "Status: " --width 30 --lines 6)
[[ -z "$choice" ]] && exit 0

case "$choice" in
    *Battery*)
        cap=$(cat /sys/class/power_supply/BAT0/capacity)
        status=$(cat /sys/class/power_supply/BAT0/status)
        energy_now=$(cat /sys/class/power_supply/BAT0/energy_now 2>/dev/null || echo 0)
        energy_full=$(cat /sys/class/power_supply/BAT0/energy_full 2>/dev/null || echo 0)
        power_now=$(cat /sys/class/power_supply/BAT0/power_now 2>/dev/null || echo 0)

        if [[ "$status" == "Full" ]]; then
            icon="$BAT_FULL"
            body="${cap}% тАФ Full"
        elif [[ "$status" == "Charging" ]]; then
            icon="$BOLT"
            if (( power_now > 0 && energy_full > energy_now )); then
                mins=$(( (energy_full - energy_now) * 60 / power_now ))
                body="${cap}% тАФ Charging тАв ~$(( mins / 60 ))h $(( mins % 60 ))m to full"
            else
                body="${cap}% тАФ Charging"
            fi
        else
            if (( cap >= 80 )); then icon="$BAT_FULL"
            elif (( cap >= 60 )); then icon="$BAT_THREE"
            elif (( cap >= 40 )); then icon="$BAT_HALF"
            elif (( cap >= 20 )); then icon="$BAT_QUARTER"
            else icon="$BAT_EMPTY"
            fi
            if (( power_now > 0 )); then
                mins=$(( energy_now * 60 / power_now ))
                body="${cap}% тАФ ${status} тАв ~$(( mins / 60 ))h $(( mins % 60 ))m remaining"
            else
                body="${cap}% тАФ ${status}"
            fi
        fi
        notify-send -u low "${icon} Battery" "$body"
        ;;
    *Internet*)
        # Connection + negotiated link speed (instant, no traffic). Lines kept short so
        # they don't wrap in mako's fixed-width box; "(active)" = the default-route iface.
        default_if=$(ip route show default 2>/dev/null | awk '/^default/{print $5; exit}')
        body=""
        for p in /sys/class/net/*; do
            ifc=$(basename "$p")
            [[ "$ifc" == lo ]] && continue
            mark=""; [[ "$ifc" == "$default_if" ]] && mark="  (active)"
            if [[ -e "$p/phy80211" ]]; then
                link=$(iw dev "$ifc" link 2>/dev/null)
                grep -q "Connected to" <<<"$link" || continue
                ssid=$(grep -m1 'SSID:'       <<<"$link" | sed 's/^[[:space:]]*SSID: //')
                rxbr=$(grep -m1 'rx bitrate:' <<<"$link" | awk '{printf "%.0f",$3}')
                body+="${WIFI}  ${ssid} ┬╖ ${rxbr} Mb/s${mark}\n"
            elif [[ -e "$p/device" ]]; then
                [[ "$(cat "$p/carrier" 2>/dev/null)" == "1" ]] || continue
                spd=$(cat "$p/speed" 2>/dev/null)
                body+="${ETH}  ${spd} Mb/s${mark}\n"
            fi
        done
        if [[ -z "$body" ]]; then
            notify-send -u normal "${NET} Internet" "Offline тАФ no active connection"
        else
            notify-send -u low "${NET} Internet" "${body%\\n}"
        fi
        ;;
    *Uptime*)
        load=$(awk '{printf "%s  %s  %s", $1, $2, $3}' /proc/loadavg)
        notify-send -u low "${CLOCK} Uptime" "$(uptime -p)\nLoad (1/5/15 min): ${load}"
        ;;
    *"CPU Temp"*)
        cpu=$(sensors 2>/dev/null | awk '/Tctl/{gsub(/[+┬░C]/,"",$2); print $2; exit}')
        gpu=$(sensors 2>/dev/null | awk '/^edge:/{gsub(/[+┬░C]/,"",$2); print $2; exit}')
        fan1=$(sensors 2>/dev/null | awk '/^fan1:/{print $2; exit}')
        fan2=$(sensors 2>/dev/null | awk '/^fan2:/{print $2; exit}')
        body="${cpu:+CPU ${cpu}┬░C}"
        [[ -n "$gpu" ]] && body+=" тАв GPU ${gpu}┬░C"
        [[ -n "$fan1" ]] && body+=" тАв Fan ${fan1}/${fan2} RPM"
        notify-send -u low "${THERM} CPU Temp" "$body"
        ;;
    *Memory*)
        mem=$(free -h | awk '/^Mem/{print $3 " used / " $2 " total (" $7 " avail)"}')
        swap=$(free -h | awk '/^Swap/{if ($3+0 > 0 || $3 ~ /[KMGT]/) print "Swap: " $3 " / " $2; else print "Swap: none"}')
        notify-send -u low "${CHIP} Memory" "${mem}\n${swap}"
        ;;
    *Time*)
        # Local + Iran + Vancouver(=Seattle, Pacific); Germany only when not local.
        local_tz=$(timedatectl show -p Timezone --value 2>/dev/null)
        body="Local      $(date '+%a %H:%M %Z')"
        [[ "$local_tz" != "Europe/Berlin" ]] && body+="\nGermany    $(TZ=Europe/Berlin date '+%a %H:%M')"
        body+="\nIran       $(TZ=Asia/Tehran date '+%a %H:%M')"
        body+="\nVancouver  $(TZ=America/Vancouver date '+%a %H:%M')"
        notify-send -u low "${WORLD} World Clock" "$body"
        ;;
esac
