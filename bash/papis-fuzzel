#!/usr/bin/env bash
# Search papis library via fuzzel dmenu, open selected PDF in sioyek.
# Falls back to browser (DOI/URL) if no file is attached.
#
# Data is read straight from the info.yaml files with yq (accurate list handling
# for tags/files, and faster than papis' Python startup). awk is used only to lay
# out the columns. -o=tsv keeps fields flat with no "---" separators.

set -uo pipefail

PAPERS="$HOME/.local/share/papis/papers"

# Per paper: ref \t year \t author-family \t title \t file-count \t "tag tag ..."
ROWS=$(yq -o=tsv \
    '[.ref, (.year // ""), (.author_list[0].family // .author // "?"), (.title // ""), ((.files // []) | length), ((.tags // []) | join(" "))]' \
    "$PAPERS"/*/info.yaml 2>/dev/null)

[[ -z "$ROWS" ]] && exit 0

# Build "ref \t filecount \t <visible>". Tags are already clean from yq; just
# prefix each with # so fuzzel's fuzzy filter matches them. Mark file-less with ↗.
DISPLAY=$(echo "$ROWS" | awk -F'\t' '{
    icon = ($5 + 0 == 0) ? " ↗" : ""
    t = $6; if (t != "") gsub(/ /, " #", t)
    tags = (t != "") ? "  #" t : ""
    printf "%s\t%s\t[%s]  %-16s  %s%s%s\n", $1, $5, $2, substr($3,1,16), substr($4,1,55), icon, tags
}')

SELECTED=$(echo "$DISPLAY" | cut -f3- \
    | fuzzel --dmenu \
        --prompt "  Papers (type a #tag to filter): " \
        --width 100 \
        --lines 15)

[[ -z "$SELECTED" ]] && exit 0

# Map the chosen visible line back to its ref + file count (no extra papis call).
match=$(echo "$DISPLAY" | awk -F'\t' -v sel="$SELECTED" '($3 == sel){print $1 "\t" $2; exit}')
REF=$(cut -f1 <<<"$match")
NFILES=$(cut -f2 <<<"$match")

[[ -z "$REF" ]] && exit 0
if [[ "${NFILES:-0}" -gt 0 ]]; then
    papis open "ref:$REF"
else
    papis browse "ref:$REF"
fi
