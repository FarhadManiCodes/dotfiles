#!/usr/bin/env bash
# sioyek-papis: upsert a reference from a sioyek text selection into papis.
#
# sioyek calls this with %{selected_text}. The selection may be a DOI (full,
# partial, or broken across PDF line breaks), a title, or a messy citation
# string. Behaviour:
#   * DOI found in the selection
#       - already in the papis library  -> open it in a new sioyek window
#       - not in the library            -> papis add --from doi (+ notify)
#   * no DOI (title / citation text)
#       - found locally by text         -> open it
#       - not local                     -> Crossref search, pick in fuzzel, upsert
#
# Notes baked in from the sioyek config quirks:
#   - sioyek splits the command on whitespace BEFORE expanding %{...} and passes
#     each piece as a separate argv, so the selection arrives across $@ -> "$*".
#   - library lookups read the entries' OWN fields straight from info.yaml with yq
#     (fast, no papis startup); matching the doi FIELD (not the `citations:` list)
#     avoids false matches on papers that merely cite the target.

set -uo pipefail

PAPERS="$HOME/.local/share/papis/papers"
note() { notify-send "papis" "$1"; }

# --- reassemble + normalise the selection ----------------------------------
RAW="$*"
NOSPACE=$(printf '%s' "$RAW" | tr -d '[:space:]')                 # for DOI rejoin
QUERY=$(printf '%s' "$RAW" | tr '\n\r\t' '   ' | tr -s ' ' \
        | sed 's/^ *//; s/ *$//')                                 # for text search
[[ -z "$QUERY" ]] && { note "Empty selection"; exit 0; }

# --- extract a DOI / arXiv id ----------------------------------------------
DOI=$(printf '%s' "$NOSPACE" | grep -oiE '10\.[0-9]{4,9}/[^[:space:]]+' | head -1)
DOI=$(printf '%s' "$DOI" | sed 's/[.,;:)]*$//')                   # strip trailing punct
ARXIV=$(printf '%s' "$NOSPACE" | grep -oiE '(arxiv:)?[0-9]{4}\.[0-9]{4,5}(v[0-9]+)?' | head -1)
ARXIV=${ARXIV#[Aa][Rr][Xx][Ii][Vv]:}

# One yq pass over the library: "doi \t ref \t title \t folder" per entry
# (folder = the info.yaml's directory). Computed once, reused by both matchers.
ENTRIES=$(yq -o=tsv '[(.doi // ""), .ref, (.title // ""), filename]' \
            "$PAPERS"/*/info.yaml 2>/dev/null | sed 's:/info\.yaml$::')

# Entries whose OWN doi equals/contains SEL (case-insensitive). Emits
# "folder \t ref \t title". ENVIRON avoids awk -v escape processing of SEL.
match_doi() {
    SEL="$1" awk -F'\t' '
        BEGIN { t = tolower(ENVIRON["SEL"]) }
        $1 != "" { d = tolower($1); if (d == t || index(d, t)) print $4 "\t" $2 "\t" $3 }' <<<"$ENTRIES"
}

# Entries whose title contains SEL on a normalised form (lowercase, non-alnum ->
# space) so "physics informed" matches "Physics-informed ...". Same columns.
match_text() {
    SEL="$1" awk -F'\t' '
        function norm(s) { s = tolower(s); gsub(/[^a-z0-9]+/, " ", s); gsub(/^ +| +$/, "", s); return s }
        BEGIN { q = norm(ENVIRON["SEL"]) }
        q != "" && $3 != "" { if (index(norm($3), q)) print $4 "\t" $2 "\t" $3 }' <<<"$ENTRIES"
}

# Open the (first) document file inside a papis folder in a new sioyek window.
open_folder() {
    local folder="$1" file
    file=$(find "$folder" -maxdepth 1 -type f \
            ! -name 'info.yaml' ! -name '*.yaml' ! -name 'notes.md' 2>/dev/null | head -1)
    if [[ -n "$file" ]]; then
        sioyek --new-window "$file" >/dev/null 2>&1 &
    else
        note "Entry is in the library but has no attached file"
    fi
}

# fuzzel dmenu picker over the lines on stdin; prints the chosen line (empty if cancelled).
pick() { fuzzel --dmenu --prompt "papis> "; }

# Present a fuzzel menu for several "folder \t ref \t title" matches; open chosen.
choose_open() {
    local -A lbl2dir=()
    local line folder rest ref title menu=() chosen
    for line in "$@"; do
        folder=${line%%$'\t'*}
        rest=${line#*$'\t'}; ref=${rest%%$'\t'*}; title=${rest#*$'\t'}
        lbl2dir["$ref | $title"]="$folder"
        menu+=("$ref | $title")
    done
    chosen=$(printf '%s\n' "${menu[@]}" | pick)
    [[ -z "$chosen" ]] && return 0
    open_folder "${lbl2dir[$chosen]}"
}

# DOI looks complete enough to add (not a bare publisher prefix).
doi_complete() { [[ "$1" =~ ^10\.[0-9]{4,9}/.{3,}$ ]]; }

add_doi() {
    local out
    if out=$(papis add --from doi "$1" --no-edit --batch 2>&1); then
        note "Added to papis: $1"
    else
        note "papis add failed: $(printf '%s' "$out" | tail -1)"
    fi
}

# =====================  main  ==============================================
if [[ -n "$DOI" ]]; then
    mapfile -t M < <(match_doi "$DOI")
    case ${#M[@]} in
        0)  if doi_complete "$DOI"; then add_doi "$DOI"
            else note "Partial DOI not in library; select the full DOI"; fi ;;
        1)  open_folder "${M[0]%%$'\t'*}" ;;
        *)  choose_open "${M[@]}" ;;        # several entries match a partial DOI
    esac
    exit 0
fi

# A DOI prefix was selected but no complete DOI could be extracted (e.g. a bare
# "10.1103/"): don't fall through to a Crossref title search -- ask for the full DOI.
if printf '%s' "$NOSPACE" | grep -qiE '10\.[0-9]{4,9}/'; then
    note "Incomplete DOI selection; select the full DOI"
    exit 0
fi

# ---- no DOI: local bibliographic search (normalised title match) ----------
mapfile -t M < <(match_text "$QUERY")
case ${#M[@]} in
    1)  open_folder "${M[0]%%$'\t'*}"; exit 0 ;;
    0)  : ;;                                # fall through to arXiv / Crossref
    *)  choose_open "${M[@]}"; exit 0 ;;
esac

# ---- arXiv id (no DOI, looks like an arXiv id) ----------------------------
if [[ -n "$ARXIV" ]]; then
    if out=$(papis add --from arxiv "$ARXIV" --no-edit --batch 2>&1); then
        note "Added arXiv:$ARXIV to papis"; exit 0
    fi
    # else fall through to Crossref text search
fi

# ---- Crossref: resolve free text -> DOI -----------------------------------
URI=$(printf '%s' "$QUERY" | jq -sRr @uri)
JSON=$(curl -sS -m 10 \
    "https://api.crossref.org/works?query.bibliographic=${URI}&rows=8&select=DOI,title,issued,author" 2>/dev/null)
mapfile -t RESULTS < <(printf '%s' "$JSON" | jq -r '
    .message.items[]?
    | "\((.title[0]) // "?") — \(((.issued."date-parts"[0][0]) // "?")) — \(.DOI)"' 2>/dev/null)

if [[ ${#RESULTS[@]} -eq 0 ]]; then
    note "No Crossref match for: $QUERY"; exit 0
fi

chosen=$(printf '%s\n' "${RESULTS[@]}" | pick)
[[ -z "$chosen" ]] && exit 0
PICKED_DOI="${chosen##* — }"
[[ -z "$PICKED_DOI" ]] && exit 0

mapfile -t M < <(match_doi "$PICKED_DOI")
if [[ ${#M[@]} -gt 0 ]]; then
    open_folder "${M[0]%%$'\t'*}"
else
    add_doi "$PICKED_DOI"
fi
