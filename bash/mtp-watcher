#!/bin/bash
# Watch for MTP device connections and auto-mount via gvfs.
# Runs as user — no root required. Add to niri autostart.

udevadm monitor --udev --subsystem-match=usb 2>/dev/null | \
while read -r _ _ action devpath _; do
    [[ "$action" != "add" ]] && continue

    # Only act on MTP devices
    mtp=$(udevadm info --query=property --path="$devpath" 2>/dev/null | grep "^ID_MTP_DEVICE=1")
    [[ -z "$mtp" ]] && continue

    # Wait for gvfs-mtp-volume-monitor to detect the new volume
    sleep 3

    bus=$(udevadm info --query=property --path="$devpath" 2>/dev/null | grep "^BUSNUM=" | cut -d= -f2)
    dev=$(udevadm info --query=property --path="$devpath" 2>/dev/null | grep "^DEVNUM=" | cut -d= -f2)

    # Strip leading zeros (gio mount URI uses decimal)
    bus=$((10#$bus))
    dev=$((10#$dev))

    gio mount "mtp://[usb:${bus},${dev}]/" 2>/dev/null || true
done
